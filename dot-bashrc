case $- in
    *i*) ;;
    *) return ;;
esac

# GNU Coreutils path alignment for color support
if command -v dircolors &>/dev/null; then
    eval "$(dircolors -b)"
    alias ls='ls --color=auto'
elif command -v gls &>/dev/null; then
    alias ls='gls --color=auto'
else
    alias ls='ls -G'
fi

# Shell options and history
set -o noclobber
shopt -s checkwinsize histappend cmdhist globstar autocd dirspell cdspell cdable_vars 2>/dev/null

PROMPT_DIRTRIM=3
CDPATH="."
bind Space:magic-space

HISTSIZE=999999
HISTFILESIZE=999999
HISTCONTROL="erasedups:ignoreboth"
HISTTIMEFORMAT='%F %T '
export HISTIGNORE="&:[ ]*:exit:ls:bg:fg:history:clear"
PROMPT_COMMAND='history -a'

# Git prompt and completion
GIT_PROMPT_PATHS=(
    "/opt/homebrew/etc/bash_completion.d/git-prompt.sh"
    "/usr/lib/git-core/git-sh-prompt"
    "/usr/share/git-core/git-prompt.sh"
    "/Library/Developer/CommandLineTools/usr/share/git-core/git-prompt.sh"
)

for path in "${GIT_PROMPT_PATHS[@]}"; do
    if [ -f "$path" ]; then
        . "$path"
        break
    fi
done

GIT_PS1_SHOWDIRTYSTATE=1
GIT_PS1_SHOWUNTRACKEDFILES=1
GIT_PS1_SHOWUPSTREAM="verbose"
GIT_PS1_SHOWCONFLICTSTATE="yes"

if command -v __git_ps1 &>/dev/null; then
    PS1='\[\033[01;34m\]\w\[\033[33m\]$(__git_ps1 " (%s)")\[\033[00m\]\$ '
else
    PS1='\[\033[01;34m\]\w\[\033[00m\]\$ '
fi

# Load package manager completions (Homebrew / Debian APT)
if ! shopt -oq posix; then
    if [ -f "$HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh" ]; then
        . "$HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh"
    elif [ -f /usr/share/bash-completion/bash_completion ]; then
        . /usr/share/bash-completion/bash_completion
    fi
fi

# Aliases and tools
[ -f ~/.bash_aliases ] && . ~/.bash_aliases

# Tmux multiplexer
if command -v tmux &>/dev/null && 
	[[ ! "$TERM" =~ screen|tmux ]] && 
	[ -z "$TMUX" ] && 
	[ -z "$VSCODE_PID" ]; then
    tmux new -As 'main'
fi
