# Host SSH directory mounted read-only into the container so it can use your keys.
# Note: macOS-only ssh config options (e.g. UseKeychain) must be guarded with
# `IgnoreUnknown UseKeychain` or Linux ssh in the container will error.
SSH_DIR=~/.ssh

DOTFILES_DIR=/home/dev/dotfiles
DOTFILES_REPO=https://github.com/HasarAli/dotfiles.git

DEEPSEEK_API_KEY=sk-fake-key-for-testing-1234567890
