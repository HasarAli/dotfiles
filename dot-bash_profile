export XDG_CONFIG_HOME="$HOME/.config"

# Default editor/pager for git, fzf, less, etc.
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="less"
export LESS="-R"   # keep ANSI colors in pager output (git, bat, etc.)

# Auto-detect Homebrew on macOS
if [[ "$OSTYPE" == "darwin"* ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Prepend user bins to take priority over system binaries
[ -d "$HOME/bin" ] && PATH="$HOME/bin:$PATH"
[ -d "$HOME/.local/bin" ] && PATH="$HOME/.local/bin:$PATH"
export PATH

# Source .bashrc if running Bash
if [ -n "$BASH_VERSION" ] && [ -f "$HOME/.bashrc" ]; then
    . "$HOME/.bashrc"
fi