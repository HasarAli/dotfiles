#!/usr/bin/env bash

# Sync submodule pointers to latest remote HEAD on commits to main
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
[[ "$branch" != "main" ]] && exit 0

# Try fetching latest from remotes, fall back to local state
git submodule update --remote 2>/dev/null || true

# Stage any updated submodule pointers
git submodule foreach --quiet 'git -C "$toplevel" add "$sm_path"'
